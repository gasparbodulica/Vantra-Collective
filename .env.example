# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real keys.

# YouTube Data API v3 key (free)
# Get one at: https://console.cloud.google.com/apis/library/youtube.googleapis.com
# Enable "YouTube Data API v3", create an API key, restrict it to your domain.
# Add this same key as a GitHub Actions secret named YOUTUBE_API_KEY.
YOUTUBE_API_KEY=
